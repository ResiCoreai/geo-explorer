{
  "name": "@ncsa/geo-explorer",
  "version": "0.0.7",
  "description": "",
  "exports": {
    ".": "./dist/index.js",
    "./index.css": "./dist/index.css"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "tailwind": "tailwindcss -i ./src/input.css -o ./dist/index.css",
    "tailwind:watch": "npm run tailwind -- --watch",
    "compile": "npm run clean && tsc && tsc-alias",
    "compile:watch": "npm run clean && tsc && concurrently \"tsc -w\" \"tsc-alias -w\"",
    "dev": "run-p tailwind:watch compile:watch",
    "build": "run-p tailwind compile",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "format": "prettier --write src",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ncsa/geo-explorer.git"
  },
  "author": "NCSA",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ncsa/geo-explorer/issues"
  },
  "homepage": "https://github.com/ncsa/geo-explorer#readme",
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.35.0",
    "globals": "^15.8.0",
    "husky": "^9.1.7",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.14",
    "tsc-alias": "^1.8.15",
    "typescript": "^5.5.4",
    "typescript-eslint": "^7.17.0"
  },
  "peerDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@adobe/react-spectrum": "^3.38.1",
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@loaders.gl/core": "^4.3.3",
    "@loaders.gl/wms": "^4.3.3",
    "@mui/icons-material": "^6.1.8",
    "@mui/material": "^6.1.8",
    "@mui/x-data-grid": "^7.23.1",
    "@reduxjs/toolkit": "^2.6.1",
    "@turf/turf": "^7.2.0",
    "@types/react-gravatar": "^2.6.14",
    "axios": "^1.7.3",
    "classnames": "^2.5.1",
    "geostyler-sld-parser": "^7.2.1",
    "loaders.gl": "^0.3.5",
    "maplibre-gl": "^4.5.0",
    "oidc-client-ts": "^3.1.0",
    "react-gravatar": "^2.6.3",
    "react-map-gl": "^7.1.7",
    "react-oidc-context": "^3.2.0",
    "react-redux": "^9.1.2",
    "xml-formatter": "^3.6.3"
  }
}
