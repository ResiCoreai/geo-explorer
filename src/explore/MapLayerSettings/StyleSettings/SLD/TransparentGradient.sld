<FeatureTypeStyle>
  <Rule>
    <RasterSymbolizer>
      <Opacity>0.3</Opacity>
      <ChannelSelection>
        <GrayChannel>
          <SourceChannelName>1</SourceChannelName>
        </GrayChannel>
      </ChannelSelection>
      <ColorMap>
        <ColorMapEntry color="#008000" quantity="70"/>
        <ColorMapEntry color="#663333" quantity="254"/>
        <ColorMapEntry color="#663333" quantity="255" opacity="0"/>
      </ColorMap>
    </RasterSymbolizer>
  </Rule>
</FeatureTypeStyle>