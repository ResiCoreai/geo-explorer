<FeatureTypeStyle>
  <Rule>
    <LineSymbolizer>
      <Stroke>
        <CssParameter name="stroke">#000000</CssParameter>
      </Stroke>
    </LineSymbolizer>
    <LineSymbolizer>
      <Stroke>
        <CssParameter name="stroke">#FF0000</CssParameter>
        <CssParameter name="stroke-dasharray">5 2</CssParameter>
      </Stroke>
      <PerpendicularOffset>5</PerpendicularOffset>
    </LineSymbolizer>
  </Rule>
</FeatureTypeStyle>